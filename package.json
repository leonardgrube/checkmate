{
	"name": "checkmate",
	"private": true,
	"version": "1.0.2",
	"description": "Cross-platform desktop app for reusable checklists and recorded runs",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/leonardgrube/checkmate"
	},
	"homepage": "https://github.com/leonardgrube/checkmate",
	"keywords": [
		"checklist",
		"tauri",
		"svelte",
		"desktop",
		"markdown"
	],
	"packageManager": "pnpm@10.33.0",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write \"src/**/*.{ts,svelte}\" \"*.{js,json}\"",
		"format:check": "prettier --check \"src/**/*.{ts,svelte}\" \"*.{js,json}\""
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.10.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.5"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-dialog": "^2.7.0"
	}
}
